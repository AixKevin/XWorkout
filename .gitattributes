* text=auto

# 确保 Dart 文件使用 LF
*.dart text eol=lf

# 确保 Markdown 文件使用 LF
*.md text eol=lf

# 确保 YAML 文件使用 LF
*.yaml text eol=lf

# 确保配置文件使用 LF
*.json text eol=lf
*.yml text eol=lf

# Flutter 相关
pubspec.yaml text eol=lf
analysis_options.yaml text eol=lf

# 忽略其他二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.otf binary
*.ttf binary
